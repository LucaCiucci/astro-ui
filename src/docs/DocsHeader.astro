---
import { pageHref } from './paths';

interface Props {
  brandName: string;
  brandLogo?: string;
  manualLabel?: string;
  homeHref?: string;
}

const {
  brandName,
  brandLogo,
  manualLabel = 'Documentation',
  homeHref = pageHref(Astro.url.pathname, '/'),
} = Astro.props;
---
<header class="docs-header">
  <button class="docs-icon-button docs-menu-button" type="button" data-docs-sidebar-open aria-label="Open navigation">
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" /></svg>
  </button>
  <a class="docs-brand" href={homeHref} aria-label={`${brandName} documentation home`}>
    {brandLogo ? (
      <img class="docs-brand__logo" src={brandLogo} alt={brandName} />
    ) : (
      <><span class="docs-brand__mark">{brandName.slice(0, 1)}</span><strong>{brandName}</strong></>
    )}
    <span class="docs-brand__divider"></span>
    <span class="docs-brand__label">{manualLabel}</span>
  </a>
  <div class="docs-header__actions">
    <button class="docs-search-trigger" type="button" data-docs-search-open><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="6.5"/><path d="m16 16 4 4"/></svg><span>Search documentation</span><kbd>Ctrl K</kbd></button>
    <button class="docs-icon-button" type="button" data-docs-theme-toggle aria-label="Toggle color theme">
      <svg class="docs-theme-icon docs-theme-icon--sun" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
      <svg class="docs-theme-icon docs-theme-icon--moon" viewBox="0 0 24 24" aria-hidden="true"><path d="M20 15.3A8.5 8.5 0 0 1 8.7 4a8.5 8.5 0 1 0 11.3 11.3Z"/></svg>
    </button>
  </div>
</header>
