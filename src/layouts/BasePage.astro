---
import BaseHtmlPage, { type Props as BaseHtmlPageProps } from './BaseHtmlPage.astro';
import MetaEx from '../components/MetaEx.astro';
import { getLastModifiedDate } from '../utils/last-modified';
export interface Props extends BaseHtmlPageProps {
  site_name?: string;
  canonical_url?: string;
  title?: string;
  author?: string;
  theme_color?: string;
  sitemap?: string;
  meta?: PageMeta;
  umami?: {
    enabled?: boolean;
    server: string;
    website_id: string;
  };
}

export interface PageMeta {
  description?: string;
  subject?: string;
  keywords?: string[];
  image?: string;
  image_alt?: string;
  date?: string;
  modified_date?: string;
  /** Open Graph type: "website" (default) or "article" */
  type?: string;
}

const { lang, site_name, canonical_url, title, author, theme_color, sitemap, meta = {}, umami } = Astro.props as Props;

const git_last_modified = getLastModifiedDate(Astro.url.pathname).toISOString().split('T')[0];
meta.modified_date = meta.modified_date ?? git_last_modified;

---
<BaseHtmlPage lang={lang}>
  <Fragment slot="head">
    <meta name="generator" content={Astro.generator} />
    <MetaEx
      title={title}
      favicon="/favicon.ico"
      icon="/favicon.svg"
      description={meta.description}
      siteName={site_name}
      canonical_url={canonical_url}
      author={author}
      image={meta.image}
      imageAlt={meta.image_alt}
      themeColor={theme_color}
      twitterCard="summary_large_image"
      date={meta.date}
      modifiedDate={meta.modified_date}
      sitemap={sitemap}
      type={meta.type}
    />
    {umami && (umami.enabled === undefined ? true : umami.enabled) && <script async defer src={`https://${umami.server}/script.js`} data-website-id={umami.website_id}></script>}
    <slot name="head" />
  </Fragment>
  <slot />
</BaseHtmlPage>
