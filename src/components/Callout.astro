---
export interface Props {
  variant?: 'note' | 'warning' | 'tip' | 'info' | 'tldr' | 'important';
  title?: string;
  id?: string;
}

const { variant = 'note', title, id: explicitId } = Astro.props as Props;

const variantTitles: Record<string, string> = {
  note: 'Note',
  warning: 'Warning',
  tip: 'Tip',
  info: 'Info',
  tldr: 'TL;DR',
  important: 'Important',
  tbw: 'TBW',
};

const displayTitle = title ?? variantTitles[variant] ?? 'Note';
const hasAnchor = !!explicitId;
---
<div class="callout" data-variant={variant} id={explicitId}>
  {hasAnchor ? (
    <a href={'#' + explicitId} class="callout-anchor">
      <span class="callout-title">{displayTitle}</span>
    </a>
  ) : (
    <span class="callout-title">{displayTitle}</span>
  )}
  <div class="callout-body">
    <slot />
  </div>
</div>

<style>
  .callout {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin: 1.5rem 0;
    border-radius: 10px;
    padding: 1rem 1.15rem;
    border: 1px solid var(--border);
    background: var(--background-raised);
  }

  .callout[data-variant="note"] {
    border-color: rgba(34, 216, 204, 0.25);
    background: rgba(34, 216, 204, 0.04);
  }

  .callout[data-variant="warning"] {
    border-color: rgba(255, 216, 61, 0.25);
    background: rgba(255, 216, 61, 0.04);
  }

  .callout[data-variant="tip"] {
    border-color: rgba(189, 245, 140, 0.25);
    background: rgba(189, 245, 140, 0.04);
  }

  .callout[data-variant="info"] {
    border-color: rgba(21, 152, 255, 0.25);
    background: rgba(21, 152, 255, 0.04);
  }

  .callout[data-variant="tldr"] {
    border-color: rgba(136, 153, 170, 0.25);
    background: rgba(136, 153, 170, 0.04);
  }

  .callout[data-variant="tbw"] {
    border-color: rgba(136, 153, 170, 0.25);
    background: rgba(136, 153, 170, 0.04);
  }

  .callout[data-variant="important"] {
    border-color: rgba(168, 85, 247, 0.3);
    background: rgba(168, 85, 247, 0.05);
  }

  .callout-anchor {
    color: inherit;
    text-decoration: none;
    position: relative;
    width: fit-content;
  }

  .callout-anchor::before {
    content: '#';
    position: absolute;
    left: -1.25ch;
    color: var(--accent);
    opacity: 0;
    transition: opacity 150ms ease;
  }

  .callout:hover .callout-anchor::before {
    opacity: 1;
  }

  .callout-title {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .callout[data-variant="note"] .callout-title {
    color: var(--accent);
  }

  .callout[data-variant="warning"] .callout-title {
    color: var(--warning);
  }

  .callout[data-variant="tip"] .callout-title {
    color: var(--accent-green);
  }

  .callout[data-variant="info"] .callout-title {
    color: var(--accent-blue);
  }

  .callout[data-variant="tldr"] .callout-title {
    color: #8899aa;
  }

  .callout[data-variant="tbw"] .callout-title {
    color: #8899aa;
  }

  .callout[data-variant="important"] .callout-title {
    color: #a855f7;
  }

  .callout-body {
    color: var(--text-soft);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .callout-body :global(p) {
    margin: 0;
  }

  .callout-body :global(p + p) {
    margin-top: 0.6rem;
  }
</style>
