---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="page-intro">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h1>{title}</h1>
  {description && <p class="description">{description}</p>}
  <div class="actions"><slot /></div>
</header>

<style>
  .page-intro {
    max-width: 46rem;
    margin-bottom: 3rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.5rem, 8vw, 4.8rem);
    line-height: 0.98;
    letter-spacing: -0.065em;
  }

  .description {
    max-width: 40rem;
    margin: 1rem 0 0;
    color: var(--text-muted);
    font-size: clamp(1rem, 2.5vw, 1.15rem);
    line-height: 1.65;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    margin-top: 1.4rem;
    gap: 0.6rem;
  }

  .actions:empty {
    display: none;
  }

  .actions :global(a) {
    border: 1px solid var(--border-strong);
    border-radius: 8px;
    padding: 0.45rem 0.8rem;
    color: var(--text);
    font-size: 0.82rem;
    font-weight: 700;
    text-decoration: none;
  }

  .actions :global(a:hover) {
    border-color: rgba(34, 216, 204, 0.5);
    background: rgba(34, 216, 204, 0.08);
    color: var(--accent);
  }
</style>
