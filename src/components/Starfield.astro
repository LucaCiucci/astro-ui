---
/*
  Starfield — programmatically generated animated background stars.

  Each layer is defined by a simple config object. The individual star
  positions, sizes and opacities are seeded-random so they're stable
  across builds but different from the old hardcoded set.

  To add a new layer, just append another config entry below.
*/

interface LayerConfig {
  label: string;
  count: number;
  rMin: number;
  rMax: number;
  opacityMin: number;
  opacityMax: number;
  color: string;         // "r,g,b" — alpha is randomised per star
  animation: string;     // CSS class suffix
  delay: number;         // animation-delay in seconds
}

const layers: LayerConfig[] = [
  {
    label: 'Dense tiny white, fast twinkle',
    count: 1000,
    rMin: 0.3, rMax: 0.6,
    opacityMin: 0.25, opacityMax: 0.75,
    color: '255,255,255',
    animation: 'fast',
    delay: 0,
  },
  {
    label: 'Dense tiny white, fast twinkle',
    count: 1000,
    rMin: 0.3, rMax: 0.6,
    opacityMin: 0.25, opacityMax: 0.75,
    color: '255,255,255',
    animation: 'fast',
    delay: 0.25,
  },
  {
    label: 'Dense tiny white, fast twinkle',
    count: 1000,
    rMin: 0.3, rMax: 0.6,
    opacityMin: 0.25, opacityMax: 0.75,
    color: '255,255,255',
    animation: 'fast',
    delay: 0.5,
  },
  {
    label: 'Dense tiny white, fast twinkle',
    count: 1000,
    rMin: 0.3, rMax: 0.6,
    opacityMin: 0.25, opacityMax: 0.75,
    color: '255,255,255',
    animation: 'fast',
    delay: 0.75,
  },
  {
    label: 'Dense tiny white, fast twinkle',
    count: 1000,
    rMin: 0.3, rMax: 0.6,
    opacityMin: 0.25, opacityMax: 0.75,
    color: '255,255,255',
    animation: 'fast',
    delay: 1.0,
