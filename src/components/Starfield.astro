    count: 10,
    rMin: 1.6, rMax: 2.4,
    opacityMin: 0.15, opacityMax: 0.3,
    color: '200,230,255',
    animation: 'slow',
    delay: 3.2,
  },
];

// ── Seeded PRNG (Lehmer / Park-Miller) ─────────────────────────────────
// Ensures the same starfield is generated every build without a seed file.
function createRng(seed: number) {
  let s = seed | 0;
  return () => {
    s = (s * 16807) % 2147483647;
    return (s - 1) / 2147483646;
  };
}

const W = 1200;
const H = 1200;

interface Star {
  cx: number;
  cy: number;
  r: number;
  opacity: number;
}

function generateStars(cfg: LayerConfig, seed: number): Star[] {
  const rng = createRng(seed);
  const stars: Star[] = [];
  for (let i = 0; i < cfg.count; i++) {
    stars.push({
      cx: Math.round(rng() * W * 10) / 10,
      cy: Math.round(rng() * H * 10) / 10,
      r: Math.round((cfg.rMin + rng() * (cfg.rMax - cfg.rMin)) * 10) / 10,
      opacity: Math.round((cfg.opacityMin + rng() * (cfg.opacityMax - cfg.opacityMin)) * 100) / 100,
    });
  }
  return stars;
}

const generated = layers.map((cfg, i) => ({
  cfg,
  stars: generateStars(cfg, 42 + i * 7),
}));
---

<svg
  class="starfield"
  viewBox="0 0 1200 1200"
  preserveAspectRatio="xMidYMid slice"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  {generated.map(({ cfg, stars }, layerIdx) => (
    <g class={`starfield-layer starfield-layer--${layerIdx + 1}`}>
      {stars.map((s) => (
        <circle cx={s.cx} cy={s.cy} r={s.r} fill={`rgba(${cfg.color},${s.opacity})`} />
      ))}
    </g>
  ))}
</svg>

<style>
  .starfield {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .starfield-layer {
    opacity: 0;
  }

  .starfield-layer--1 {
    animation: starfield-twinkle 1s ease-in-out infinite;
  }

  .starfield-layer--2 {
    animation: starfield-twinkle-slow 5.4s ease-in-out infinite;
    animation-delay: 1.8s;
  }

  .starfield-layer--3 {
    animation: starfield-pulse 8s ease-in-out infinite;
    animation-delay: 0.6s;
  }

  .starfield-layer--4 {
    animation: starfield-twinkle-slow 7s ease-in-out infinite;
    animation-delay: 3.2s;
  }

  @keyframes starfield-twinkle {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.25; }
  }

  @keyframes starfield-twinkle-slow {
    0%, 100% { opacity: 0.9; }
    50% { opacity: 0.1; }
  }

  @keyframes starfield-pulse {
    0%, 100% { opacity: 0.7; }
    33% { opacity: 0.15; }
    66% { opacity: 0.5; }
  }
</style>
