---
interface Props {
  href: string;
  role?: "normal" | "primary";
  /** Whether to open the link in a new tab. Defaults to true for backward compatibility. */
  newTab?: boolean;
}
const { href, role = "normal", newTab = false } = Astro.props as Props;

const className = `hero-button ${role === "primary" ? "hero-button--primary" : ""}`;
---

<a
  class={className}
  href={href}
  target={newTab ? "_blank" : undefined}
  rel={newTab ? "noopener noreferrer" : undefined}
>
  <slot />
</a>
