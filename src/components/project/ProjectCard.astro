---
import Md from '../Md.astro';
interface Props {
  title: string;
  description?: string;
  href?: string;
  meta?: string;
  tags?: string[];
  status?: 'complete' | 'archive' | 'external';
  image?: string;
  imageAlt?: string;
}

const {
  title,
  description,
  href,
  meta,
  tags = [],
  status = 'complete',
  image,
  imageAlt = '',
} = Astro.props;
---

<article class="card">
  {image && <img src={image} alt={imageAlt} class="card-image" />}
  <div class="card-body">
    <div class="topline">
      {meta && <span>{meta}</span>}
      <span class="status">{status}</span>
    </div>
    <h2>{href ? <a href={href}><Md kind="inline" text={title} /></a> : <Md kind="inline" text={title} />}</h2>
    {description && <Md kind="block" text={description} />}
    {tags.length > 0 && <ul>{tags.map(tag => <li>{tag}</li>)}</ul>}
    {href && <a class="open" href={href}>Open project <span aria-hidden="true">↗</span></a>}
  </div>
</article>

<style>
  .card {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border);
    border-left: 2px solid var(--accent);
    border-radius: 0 12px 12px 0;
    background:
      linear-gradient(120deg, var(--hover-accent-subtle), transparent 55%),
      var(--background-raised);
  }

  .card-body {
    padding: 1.2rem;
  }

  .topline {
    display: flex;
    min-height: 1.25rem;
    justify-content: space-between;
    color: var(--text-muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .card-image {
    float: right;
    width: auto;
    max-width: 8rem;
    max-height: 6rem;
    object-fit: contain;
    border-radius: 6px;
    margin: 0.8rem 0.8rem 0.4rem 0.8rem;
    border: 1px solid var(--border);
  }

  .status {
    color: var(--accent);
  }

  h2 {
    margin: 0.65rem 0 0;
    font-size: 1.12rem;
    line-height: 1.35;
  }

  h2 a {
    color: var(--text);
    text-decoration: none;
  }

  h2 a:hover {
    color: var(--accent);
  }

  p {
    margin: 0.55rem 0 0;
    color: var(--text-muted);
    font-size: 0.88rem;
    line-height: 1.6;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    margin: 0;
    padding: 1.2rem 0 0;
    gap: 0.35rem;
    list-style: none;
    clear: both;
  }

  li {
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.18rem 0.5rem;
    color: var(--text-soft);
    font-size: 0.7rem;
    font-weight: 650;
  }

  .open {
    margin-top: 1rem;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 700;
    text-decoration: none;
  }
</style>
